<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itxiang.evidence.mapper.JdAnalysisMapper">

    <resultMap id="JdAnalysisReportResultMap" type="com.itxiang.evidence.entity.JdAnalysisReport">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="reportKey" column="report_key"/>
        <result property="jobDescription" column="job_description"/>
        <result property="matchScore" column="match_score"/>
        <result property="masteredPercent" column="mastered_percent"/>
        <result property="partialPercent" column="partial_percent"/>
        <result property="gapPercent" column="gap_percent"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="JdAnalysisSkillResultMap" type="com.itxiang.evidence.entity.JdAnalysisSkill">
        <id property="id" column="id"/>
        <result property="reportId" column="report_id"/>
        <result property="skillName" column="skill_name"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <resultMap id="JdLearningPlanItemResultMap" type="com.itxiang.evidence.entity.JdLearningPlanItem">
        <id property="id" column="id"/>
        <result property="reportId" column="report_id"/>
        <result property="stepNo" column="step_no"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insertReport" parameterType="com.itxiang.evidence.entity.JdAnalysisReport"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO jd_analysis_report (
            user_id,
            report_key,
            job_description,
            match_score,
            mastered_percent,
            partial_percent,
            gap_percent
        )
        VALUES (
            #{userId},
            #{reportKey},
            #{jobDescription},
            #{matchScore},
            #{masteredPercent},
            #{partialPercent},
            #{gapPercent}
        )
    </insert>

    <insert id="insertSkill" parameterType="com.itxiang.evidence.entity.JdAnalysisSkill">
        INSERT INTO jd_analysis_skill (
            report_id,
            skill_name,
            status
        )
        VALUES (
            #{reportId},
            #{skillName},
            #{status}
        )
    </insert>

    <insert id="insertPlanItem" parameterType="com.itxiang.evidence.entity.JdLearningPlanItem">
        INSERT INTO jd_learning_plan_item (
            report_id,
            step_no,
            title,
            description
        )
        VALUES (
            #{reportId},
            #{stepNo},
            #{title},
            #{description}
        )
    </insert>

    <select id="findLatestReportByUserId" resultMap="JdAnalysisReportResultMap">
        SELECT
            id,
            user_id,
            report_key,
            job_description,
            match_score,
            mastered_percent,
            partial_percent,
            gap_percent,
            created_at,
            updated_at
        FROM jd_analysis_report
        WHERE user_id = #{userId}
        ORDER BY updated_at DESC, id DESC
        LIMIT 1
    </select>

    <select id="findSkillsByReportId" resultMap="JdAnalysisSkillResultMap">
        SELECT
            id,
            report_id,
            skill_name,
            status,
            created_at
        FROM jd_analysis_skill
        WHERE report_id = #{reportId}
        ORDER BY id ASC
    </select>

    <select id="findPlanByReportId" resultMap="JdLearningPlanItemResultMap">
        SELECT
            id,
            report_id,
            step_no,
            title,
            description,
            created_at
        FROM jd_learning_plan_item
        WHERE report_id = #{reportId}
        ORDER BY step_no ASC, id ASC
    </select>
</mapper>
