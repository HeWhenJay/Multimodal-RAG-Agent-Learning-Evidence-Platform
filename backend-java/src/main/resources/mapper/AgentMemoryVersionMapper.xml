<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itxiang.evidence.mapper.AgentMemoryVersionMapper">

    <resultMap id="AgentMemoryVersionResultMap" type="com.itxiang.evidence.entity.AgentMemoryVersion">
        <id property="id" column="id"/>
        <result property="memoryId" column="memory_id"/>
        <result property="previousMemoryId" column="previous_memory_id"/>
        <result property="relationType" column="relation_type"/>
        <result property="decision" column="decision"/>
        <result property="reason" column="reason"/>
        <result property="decidedBy" column="decided_by"/>
        <result property="userId" column="user_id"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.itxiang.evidence.entity.AgentMemoryVersion">
        INSERT INTO agent_memory_version (
            id,
            memory_id,
            previous_memory_id,
            relation_type,
            decision,
            reason,
            decided_by,
            user_id
        )
        VALUES (
            #{id},
            #{memoryId},
            #{previousMemoryId},
            #{relationType},
            #{decision},
            #{reason},
            #{decidedBy},
            #{userId}
        )
    </insert>

    <select id="findByMemoryId" resultMap="AgentMemoryVersionResultMap">
        SELECT
            id,
            memory_id,
            previous_memory_id,
            relation_type,
            decision,
            reason,
            decided_by,
            user_id,
            created_at
        FROM agent_memory_version
        WHERE user_id = #{userId}
          AND (memory_id = #{memoryId} OR previous_memory_id = #{memoryId})
        ORDER BY created_at DESC
    </select>
</mapper>
