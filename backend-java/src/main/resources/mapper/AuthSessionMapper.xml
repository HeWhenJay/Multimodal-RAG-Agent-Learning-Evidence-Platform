<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itxiang.evidence.mapper.AuthSessionMapper">

    <resultMap id="AuthSessionResultMap" type="com.itxiang.evidence.entity.AuthSession">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="tokenHash" column="token_hash"/>
        <result property="rememberMe" column="remember_me"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="revoked" column="revoked"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.itxiang.evidence.entity.AuthSession"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO auth_session (
            user_id,
            token_hash,
            remember_me,
            expires_at,
            revoked
        )
        VALUES (
            #{userId},
            #{tokenHash},
            #{rememberMe},
            #{expiresAt},
            #{revoked}
        )
    </insert>

    <select id="findActiveByTokenHash" resultMap="AuthSessionResultMap">
        SELECT
            id,
            user_id,
            token_hash,
            remember_me,
            expires_at,
            revoked,
            created_at,
            updated_at
        FROM auth_session
        WHERE token_hash = #{tokenHash}
          AND revoked = FALSE
          AND expires_at &gt; #{now}
    </select>

    <update id="revokeByTokenHash">
        UPDATE auth_session
        SET revoked = TRUE,
            updated_at = CURRENT_TIMESTAMP
        WHERE token_hash = #{tokenHash}
    </update>
</mapper>
