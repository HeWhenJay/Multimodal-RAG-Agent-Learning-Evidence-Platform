<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itxiang.evidence.mapper.VideoSliceMapper">

    <resultMap id="VideoSliceResultMap" type="com.itxiang.evidence.entity.VideoSlice">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="topic" column="topic"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findRecent" resultMap="VideoSliceResultMap">
        SELECT
            id,
            title,
            topic,
            start_time,
            end_time,
            status,
            created_at,
            updated_at
        FROM video_slice
        ORDER BY updated_at DESC, id DESC
        LIMIT #{limit}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(1) FROM video_slice
    </select>

    <select id="countSince" resultType="long">
        SELECT COUNT(1)
        FROM video_slice
        WHERE created_at >= #{startTime}
    </select>
</mapper>
