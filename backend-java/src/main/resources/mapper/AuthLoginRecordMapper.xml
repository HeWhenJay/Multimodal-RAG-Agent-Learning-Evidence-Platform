<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itxiang.evidence.mapper.AuthLoginRecordMapper">

    <insert id="insert" parameterType="com.itxiang.evidence.entity.AuthLoginRecord"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO auth_login_record (
            user_id,
            account,
            success,
            failure_reason,
            ip_address,
            user_agent
        )
        VALUES (
            #{userId},
            #{account},
            #{success},
            #{failureReason},
            #{ipAddress},
            #{userAgent}
        )
    </insert>
</mapper>
