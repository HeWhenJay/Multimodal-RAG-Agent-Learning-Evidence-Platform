<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itxiang.evidence.mapper.ResumeEvidenceAlignmentMapper">

    <resultMap id="ResumeEvidenceAlignmentResultMap" type="com.itxiang.evidence.entity.ResumeEvidenceAlignment">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="requirement" column="requirement"/>
        <result property="evidence" column="evidence"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.itxiang.evidence.entity.ResumeEvidenceAlignment">
        INSERT INTO resume_evidence_alignment (
            user_id,
            requirement,
            evidence,
            status
        )
        VALUES (
            #{userId},
            #{requirement},
            #{evidence},
            #{status}
        )
    </insert>

    <delete id="deleteByUserId">
        DELETE FROM resume_evidence_alignment
        WHERE user_id = #{userId}
    </delete>

    <select id="findRecentByUserId" resultMap="ResumeEvidenceAlignmentResultMap">
        SELECT
            id,
            user_id,
            requirement,
            evidence,
            status,
            created_at,
            updated_at
        FROM resume_evidence_alignment
        WHERE user_id = #{userId}
        ORDER BY updated_at DESC, id DESC
        LIMIT #{limit}
    </select>
</mapper>
